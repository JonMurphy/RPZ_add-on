#!/bin/bash
set -o errexit -o nounset -o pipefail

version="2025-12-21 - v29"

##############################     Functions     ##############################
# Extract hit count for RPZ zone from pre-computed "name count" list
get_rpz_hits() {
    local name=$1
    local rpzNameCount=$2
    grep "^${name}\s" <<< "${rpzNameCount}" | awk '{print $2}' || echo "n/a"
}

# Extract CNAME line count for RPZ zone from pre-computed file:count list
get_rpz_lines() {
    local name=$1
    local cnameCount=$2
	grep --fixed-strings "/${name}.rpz" <<< "${cnameCount}" | awk -F: '{print $2}' || echo "n/a"
}

# Extract last modified date for RPZ zone from pre-computed "date file" list
get_rpz_moddate() {
    local name=$1
    local modDateList=$2
    grep --fixed-strings "/${name}.rpz" <<< "${modDateList}" | awk '{ print $1 }' || echo "n/a"
}

# Check if RPZ zone is active (loaded + non-empty)
is_rpz_list_active() {
    local name=$1
    local ucListAuthZones=$2
    local cnameCount=$3
	#	  Require it in list_auth_zones and have non-zero CNAME count
    grep --quiet "^${name}\.rpz" <<< "${ucListAuthZones}" && \
        ! grep --quiet "/${name}\.rpz:0$" <<< "${cnameCount}"
}


################################     Main     ################################

weeks="2"                   #   default to two message logs
sortBy="name"               #   default "by name"
rpzActive="enabled"         #   default "enabled only"

while [[ $# -gt 0 ]] ; do
    case "$1" in
        --by-names | --by-name | name )				sortBy="name"		;;

        --by-hits | --by-hit | hits | hit )     	sortBy="hit"		;;

        --by-lines | --by-line | lines | line )    	sortBy="line"		;;

        --by-effect )								sortBy="effect" 	;;

        --enabled-only )            				rpzActive="enabled" ;;

        --active-all | --all | all )      			rpzActive="all"     ;;

        [0-9] | [0-9][0-9] )        				weeks=$1			;;

        *)	echo "Unknown option: $1" >&2 ; exit 1						;;

    esac
    shift       # Shift after checking all the cases to get next option
done

#  get the list of message logs for N weeks
readarray -t messageLogs < <(
    find /var/log -maxdepth 1 -name 'messages*' -type f |
    sort --version-sort |
    head -"${weeks}")

# #  get the list of RPZ names & counts from the message log(s)
rpzNameCount=$(
  printf '%s\0' "${messageLogs[@]}" |
  xargs -0 zgrep --text --fixed-strings 'info: rpz: applied' |
  awk '$10 ~ /\[\w*]/ { print $10 }' |
    sort |
    uniq --count
)

#  flip results and remove brackets [ and ]
rpzNameCount=$(
	echo "${rpzNameCount}" |
    awk '{ print $2, $1 }' |
    sed --regexp-extended 's|^\[(.*)\]|\1|' )

#  get list of RPZ files
readarray -t rpzFileList < <( find /etc/unbound/zonefiles -type f -iname '*.rpz' )

#  get basename of those files
rpzBaseNames=$(
    printf '%s\n' "${rpzFileList[@]}" |
    sed 's|/etc/unbound/zonefiles/||g ; s|\.rpz||g ;' )

#  grab only names
rpzNames=$( echo "${rpzNameCount}" | awk '{ print $1 }' )

#  add to rpzNames and drop duplicate names
rpzNames=$( echo "${rpzNames}"$'\n'"${rpzBaseNames}" | sort --unique )

#  get CNAME count for each RPZ list
cnameCount=$( grep --count --fixed-strings ' CNAME ' -- "${rpzFileList[@]}" )

#  get modified date each RPZ
modDateList=$( stat -c '%.10y  %n' -- "${rpzFileList[@]}" )

ucListAuthZones=$( unbound-control list_auth_zones )

#  get width of RPZ names
pWidth=$( echo "${rpzNames}" | awk '{ print $1"   " }' | wc -L )
pFormat="%-${pWidth}s %-8s %-8s %8s %12s %12s\n"

#  print title line
printf "${pFormat}" "name" "hits" "active" "lines" " hits/line" "last download"
printf -- "----------------------------------------------------------------------\n"

theResults=""
totalLines=0
totalHits=0

while read -r theName ; do
	#  is this RPZ list active?
    if is_rpz_list_active "${theName}" "${ucListAuthZones}" "${cnameCount}"; then
        theActive="enabled"
    else
        theActive="disabled"
		# 	When rpzActive=all: include disabled zones + their hit counts in totals
        [[ "${rpzActive}" == enabled ]] && continue
    fi

	#  get hit count for the RPZ name.  Only reaches here if: enabled OR rpzActive=all
	theHits=$(get_rpz_hits "${theName}" "${rpzNameCount}")

    #  get line count for the RPZ name
	theLines=$(get_rpz_lines "${theName}" "${cnameCount}")

    #  get modification date for the RPZ name
    theModDate=$(get_rpz_moddate "${theName}" "${modDateList}")

	#  total it up
	[[ "${theHits}" != "n/a" ]] && totalHits=$(( totalHits + theHits ))
	[[ "${theLines}" != "n/a" ]] && totalLines=$(( totalLines + theLines ))

    hitsPerLine="n/a"
    if [[ "${theLines}" != "n/a" && "${theHits}" != "n/a" && "${theLines}" -gt 2 ]]; then
        hitsPerLine=$(( 100 * theHits / theLines ))
    fi

    #  add to results list
    theResults+="${theName} ${theHits} ${theActive} ${theLines} ${hitsPerLine} ${theModDate}"$'\n'

done <<< "${rpzNames}"

case "${sortBy}" in
    #  sort by "active" then by "name"
    name) sortArg=(-k3,3r -k1,1)			;;

    #  sort by "active" then by "hits" then by "name"
    hit)  sortArg=(-k3,3r -k2,2nr -k1,1)	;;

    #  sort by "active" then by "lines" then by "name"
    line) sortArg=(-k3,3r -k4,4nr -k1,1)	;;

    #  sort by "active" then by "effect" then by "name"
    effect) sortArg=(-k3,3r -k5,5nr -k1,1)	;;

	# default to name
	*) sortArg=(-k3,3r -k1,1) ;;
esac

#  remove blank lines, sort, print as columns
echo "${theResults}" |
    awk '!/^[[:space:]]*$/' |
    sort "${sortArg[@]}"    |
    awk --assign=width="${pWidth}" \
        '{ printf "%-*s %-8s %-8s %8s %10s %% %12s\n", width, $1, $2, $3, $4, $5, $6 }'

printf "${pFormat}" "" "=======" "" "========" "" ""
printf "${pFormat}" "Totals -->" "${totalHits}" "" "${totalLines}" "" ""

exit
